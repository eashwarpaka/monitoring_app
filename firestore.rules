rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if user is super admin
    function isSuperAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin';
    }

    // Function to check if user is restaurant owner for specific restaurant
    function isOwnerOf(restaurantId) {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'restaurant_owner' &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.restaurant_id == restaurantId;
    }

    // Function to check if request is coming from a POS device (assumed via custom claim or specific condition)
    // For simplicity based on prompt, allowing write but not read from anonymous or specific role
    function isPosDevice() {
      return request.auth != null && request.auth.token.pos == true; 
      // or similar pos authentication mechanism
    }

    match /users/{userId} {
      allow read: if isSuperAdmin() || request.auth.uid == userId;
    }

    match /restaurants/{restaurantId} {
      allow read: if isSuperAdmin() || isOwnerOf(restaurantId);
    }

    match /branches/{branchId} {
      allow read: if isSuperAdmin() || isOwnerOf(resource.data.restaurant_id);
    }

    match /pos_devices/{deviceId} {
      // Assuming a POS is tied to a branch, and owner can read branch
      allow read: if isSuperAdmin() || 
        isOwnerOf(get(/databases/$(database)/documents/branches/$(resource.data.branch_id)).data.restaurant_id);
    }

    match /orders/{orderId} {
      allow read: if isSuperAdmin() || isOwnerOf(resource.data.restaurant_id);
      allow write: if isPosDevice();
    }
  }
}
